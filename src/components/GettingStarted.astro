---
interface Step {
  title: string;
  description: string;
}

interface Cta {
  text: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  steps: Step[];
  cta: Cta;
  ctaSubtitle?: string;
}

const { title, description, steps, cta, ctaSubtitle } = Astro.props;
---

<section id="getting-started" class="py-20 sm:py-32 border-t border-arena-border">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center">
      <h2 class="text-3xl font-light tracking-tight text-arena-ink sm:text-4xl">{title}</h2>
      <p class="mt-4 text-lg leading-8 text-arena-muted">{description}</p>
    </div>
    <div class="mt-16 max-w-2xl mx-auto">
      <ul class="space-y-10">
        {steps.map((step, index) => (
          <li class="flex items-start">
            <div class="flex-shrink-0 h-10 w-10 bg-sky-500 rounded-full flex items-center justify-center text-white font-bold text-lg">
              {index + 1}
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-semibold leading-6 text-arena-ink">{step.title}</h3>
              <p class="mt-2 text-base text-arena-muted">{step.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
    <div class="mt-16 text-center">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <!-- Fork on GitHub: official GitHub black -->
        <a
          href={cta.href}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-white bg-[#24292e] rounded-full hover:bg-[#444d56] transition-colors"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          {cta.text}
        </a>
        <!-- View Demo: sky blue (follow the blue) -->
        <a
          href="#demo"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-white bg-sky-500 rounded-full hover:bg-sky-600 transition-colors"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          View Demo
        </a>
      </div>
      {ctaSubtitle && (
        <p class="mt-4 text-sm text-arena-muted">{ctaSubtitle}</p>
      )}
    </div>
  </div>
</section>

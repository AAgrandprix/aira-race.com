---
interface Props {
  youtubeChannelUrl: string;
  loginUrl?: string;
}

const { youtubeChannelUrl, loginUrl = '/login' } = Astro.props;
---

<section id="demo" class="py-20 sm:py-32 border-t border-arena-border bg-arena-bg">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <!-- Section header -->
    <div class="text-center mb-12">
      <span class="inline-block text-xs font-semibold tracking-widest text-orange-500 uppercase mb-3">Quick Tour</span>
      <h2 class="text-3xl font-light tracking-tight text-arena-ink sm:text-4xl">
        Fork to first race<br class="hidden sm:block" /> in under 3 minutes.
      </h2>
    </div>

    <!-- Video area -->
    <div
      class="relative mx-auto max-w-3xl rounded-2xl overflow-hidden border border-arena-border shadow-lg bg-zinc-950"
      x-data="{ playing: false }"
    >
      <!-- Poster + play button (shown before play) -->
      <div
        x-show="!playing"
        class="relative aspect-video cursor-pointer group"
        @click="playing = true; $nextTick(() => $refs.video.play())"
      >
        <img
          src="/fork-demo-poster.jpg"
          alt="Fork to first race demo"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/30 group-hover:bg-black/40 transition-colors"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="h-16 w-16 rounded-full bg-white/90 flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform">
            <svg class="h-7 w-7 text-zinc-900 ml-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Inline video (shown after play) -->
      <video
        x-show="playing"
        x-ref="video"
        src="/top-fork-demo.mp4"
        class="w-full aspect-video"
        controls
        playsinline
        style="display: none;"
      ></video>
    </div>

    <!-- CTAs below video -->
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <!-- Primary: Sign up / Login -->
      <a
        href={loginUrl}
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 text-base font-semibold text-white bg-sky-500 rounded-full hover:bg-sky-600 transition-colors"
      >
        <!-- Official Google G (4-color) on white bg pill -->
        <span class="flex items-center justify-center h-5 w-5 rounded-full bg-white shrink-0">
          <svg class="h-3 w-3" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        </span>
        Start with Login
      </a>

      <!-- Secondary: YouTube -->
      <a
        href={youtubeChannelUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 text-base font-semibold text-arena-ink border border-arena-border rounded-full hover:border-red-400 hover:text-red-600 transition-colors"
      >
        <!-- YouTube icon -->
        <svg class="h-4 w-4 text-red-500" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        Learn more on YouTube
      </a>
    </div>

  </div>
</section>

---
import HeroAnimation from './HeroAnimation.astro';

interface Props {
  tagline: string;
  subtitle: string;
  primaryCTA: { text: string; href: string };
  secondaryCTA: { text: string; href: string };
}

const { tagline, subtitle, primaryCTA, secondaryCTA } = Astro.props;
---

<!-- Hero: sky-50 ambient light + grid overlay -->
<section class="relative min-h-screen flex items-center justify-center px-4 sm:px-6 pt-14 overflow-hidden">
  <!-- Ambient gradient: sky glow at the top -->
  <div class="absolute inset-0 bg-gradient-to-b from-sky-50 via-zinc-50 to-zinc-50 pointer-events-none" aria-hidden="true"></div>
  <!-- Grid overlay -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: linear-gradient(to right, #e4e4e7 1px, transparent 1px), linear-gradient(to bottom, #e4e4e7 1px, transparent 1px); background-size: 48px 48px; opacity: 0.4;"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-3xl mx-auto text-center">
    <h1 class="text-5xl sm:text-6xl md:text-7xl font-light tracking-tight text-arena-ink">
      {tagline}
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-arena-muted max-w-2xl mx-auto leading-relaxed whitespace-pre-line">
      {subtitle}
    </p>
    <div class="mt-10">
      <HeroAnimation />
    </div>
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <!-- Primary: Start the Tutorial → Robot Blue -->
      <a
        href={primaryCTA.href}
        target={primaryCTA.href.startsWith('http') ? '_blank' : undefined}
        rel={primaryCTA.href.startsWith('http') ? 'noopener noreferrer' : undefined}
        class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-sky-500 rounded-full hover:bg-sky-600 transition-colors"
      >
        {primaryCTA.text}
      </a>
      <!-- Secondary: View Competitions → orange -->
      <a
        href={secondaryCTA.href}
        class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-orange-500 rounded-full hover:bg-orange-600 transition-colors"
        target={secondaryCTA.href.startsWith('http') ? '_blank' : undefined}
        rel={secondaryCTA.href.startsWith('http') ? 'noopener noreferrer' : undefined}
      >
        {secondaryCTA.text}
      </a>
    </div>
  </div>
</section>

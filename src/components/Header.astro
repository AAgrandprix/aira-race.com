---
import landing from '../data/landing.json';

export interface Props {
  isLoggedIn?: boolean;
}

const { isLoggedIn = false } = Astro.props;

const navLinks = [
  { text: 'Tutorial', href: '/getting-started' },
  { text: 'Competitions', href: '/competitions' },
  { text: 'Ranking', href: '/#ranking' },
  { text: 'Vision', href: '/vision' },
];

const loginUrl = '/login';
const dashboardUrl = '/dashboard';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-zinc-950/90 backdrop-blur-md border-b border-zinc-800">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-14">
      {/* Site branding — invert to make black logo visible on dark bg */}
      <div class="shrink-0 mr-4">
        <a href="/">
          <img class="h-9 w-auto rounded-md invert" src="/mark-aira.png" alt={landing.site.name} />
        </a>
      </div>

      {/* Desktop navigation */}
      <nav class="hidden md:flex md:grow">
        <ul class="flex grow justify-center flex-wrap items-center">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="font-medium text-zinc-400 hover:text-sky-400 px-4 py-3 flex items-center transition-colors duration-150">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {/* Login/Dashboard button — outline style, glows on hover */}
      <div class="flex-none">
        {isLoggedIn ? (
          <a
            href={dashboardUrl}
            class="inline-flex items-center px-4 py-1.5 text-sm font-medium text-zinc-300 border border-zinc-700 rounded-md hover:border-white hover:text-white transition-colors"
          >
            Dashboard
          </a>
        ) : (
          <a
            href={loginUrl}
            class="inline-flex items-center px-4 py-1.5 text-sm font-medium text-zinc-300 border border-zinc-700 rounded-md hover:border-white hover:text-white transition-colors"
          >
            Login
          </a>
        )}
      </div>

      {/* TODO: Add mobile menu */}
    </div>
  </div>
</header>

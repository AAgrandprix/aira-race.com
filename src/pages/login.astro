---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import landing from '../data/landing.json';

const pageTitle = "Login | aira";
const pageDescription = "Login to your aira account to start competing.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={landing.site.url + '/login'}
  ogImage={landing.site.ogImage}
  siteName={landing.site.name}
  ogTitle={pageTitle}
  ogDescription={pageDescription}
  lang={landing.site.lang}
>
  <Header />
  <main class="flex-grow">
    <div class="min-h-full flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
      <div x-data="{ agreed: false }" class="max-w-md w-full space-y-8 p-10 bg-slate-900 rounded-xl border border-slate-700">
        <div>
          <h2 class="mt-6 text-center text-3xl font-extrabold text-white">
            Log in to aira
          </h2>
          <p class="mt-2 text-center text-sm text-slate-400">
            to start your first AI race
          </p>
        </div>
        
        <div class="relative flex items-start mt-5">
          <div class="flex items-center h-5">
            <input 
              id="agreement" 
              x-model="agreed"
              aria-describedby="agreement-description" 
              name="agreement" 
              type="checkbox" 
              class="focus:ring-sky-500 h-4 w-4 text-sky-600 bg-slate-800 border-slate-600 rounded"
            >
          </div>
          <div class="ml-3 text-sm">
            <label for="agreement" class="font-medium text-slate-300">
              I have read and agree to the
              <a href="/agreement" target="_blank" class="text-sky-400 hover:text-sky-500 underline">
                Participant Agreement
              </a>.
            </label>
            <p id="agreement-description" class="text-slate-500">
              You must agree to the terms before logging in.
            </p>
          </div>
        </div>

        <div>
          <button 
            type="button" 
            :disabled="!agreed" 
            class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white transition-colors"
            :class="{ 
              'bg-sky-600 hover:bg-sky-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-sky-500 focus:ring-offset-slate-900': agreed, 
              'bg-slate-700 cursor-not-allowed': !agreed 
            }"
          >
            <svg class="w-5 h-5 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="48px" height="48px"><path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"></path><path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"></path><path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.222,0-9.582-3.333-11.303-8H24v-8H12.703C12.703,20,24,20,24,20v-8H24c-6.627,0-12,5.373-12,12C12,35.627,17.278,41.2,24,44z"></path><path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"></path></svg>
            Log in with Google
          </button>
        </div>
      </div>
    </div>
  </main>
  <Footer {...landing.footer} />
</Layout>

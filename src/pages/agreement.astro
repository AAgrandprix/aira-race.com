---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import landing from '../data/landing.json';

import { Content } from '../content/agreements/main.md';

const pageTitle = "Participant Agreement | aira";
const pageDescription = "aira Competition Participant Agreement";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={landing.site.url + '/agreement'}
  ogImage={landing.site.ogImage}
  siteName={landing.site.name}
  ogTitle={pageTitle}
  ogDescription={pageDescription}
  lang={landing.site.lang}
>
  <Header />
  <main class="flex-grow">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-24">
      <article class="prose prose-invert max-w-none prose-h1:text-3xl prose-h1:text-white prose-h2:text-2xl prose-h2:text-sky-300">
        <Content />
      </article>
    </div>
  </main>
  <Footer {...landing.footer} />
</Layout>

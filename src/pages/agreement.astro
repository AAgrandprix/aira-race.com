---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import landing from '../data/landing.json';

import { Content } from '../content/agreements/main.md';

const pageTitle = "Participant Agreement | aira";
const pageDescription = "aira Competition Participant Agreement";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={landing.site.url + '/agreement'}
  ogImage={landing.site.ogImage}
  siteName={landing.site.name}
  ogTitle={pageTitle}
  ogDescription={pageDescription}
  lang={landing.site.lang}
>
  <Header />
  <main class="bg-arena-bg min-h-screen">

    <!-- Page hero -->
    <div class="relative pt-24 pb-16 px-4 sm:px-6 border-b border-arena-border overflow-hidden">
      <div
        class="absolute inset-0 pointer-events-none"
        style="background-image: linear-gradient(to right, #e4e4e7 1px, transparent 1px), linear-gradient(to bottom, #e4e4e7 1px, transparent 1px); background-size: 48px 48px; opacity: 0.4;"
        aria-hidden="true"
      ></div>
      <div class="relative max-w-3xl mx-auto text-center">
        <span class="inline-block text-xs font-semibold tracking-widest text-orange-500 uppercase mb-4">Legal</span>
        <h1 class="text-4xl sm:text-5xl font-light tracking-tight text-arena-ink">
          Participant Agreement
        </h1>
        <p class="mt-6 text-lg text-arena-muted max-w-xl mx-auto">
          Please read this agreement carefully before participating in any competition on the aira platform.
        </p>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
      <div class="rounded-2xl border border-arena-border bg-white p-8 sm:p-12 shadow-sm">
        <article class="
          prose max-w-none
          prose-headings:font-semibold
          prose-h1:text-2xl prose-h1:text-arena-ink prose-h1:border-b prose-h1:border-arena-border prose-h1:pb-4 prose-h1:mb-8
          prose-h2:text-xl prose-h2:text-arena-ink prose-h2:mt-10 prose-h2:mb-4
          prose-p:text-arena-muted prose-p:leading-7
          prose-strong:text-arena-ink prose-strong:font-semibold
          prose-a:text-sky-600 prose-a:no-underline hover:prose-a:underline
          prose-blockquote:border-l-orange-400 prose-blockquote:bg-orange-50 prose-blockquote:rounded-r-lg prose-blockquote:px-6 prose-blockquote:py-4 prose-blockquote:not-italic prose-blockquote:text-arena-muted
          prose-code:bg-zinc-100 prose-code:text-zinc-700 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-xs prose-code:font-mono prose-code:before:content-none prose-code:after:content-none
          prose-ul:text-arena-muted prose-ol:text-arena-muted
          prose-li:text-arena-muted
          prose-hr:border-arena-border
        ">
          <Content />
        </article>
      </div>
    </div>

  </main>
  <Footer {...landing.footer} />
</Layout>

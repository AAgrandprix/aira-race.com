---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import landing from '../data/landing.json';

interface Competition {
  ID: string;
  Title: string;
  Status: string;         // 'Active' | 'Upcoming' | 'Ended'
  Type?: string;          // 'TimeAttack' | 'Race'
  Description?: string;
  StartDate?: string;
  EndDate?: string;
  Prize?: string;
  DetailUrl?: string;
}

let competitions: Competition[] = [];
let fetchError = false;

try {
  const apiUrl = import.meta.env.PUBLIC_GAS_API_URL;
  if (!apiUrl) {
    fetchError = true;
  } else {
    const response = await fetch(apiUrl);
    if (!response.ok) throw new Error(`Status ${response.status}`);
    competitions = await response.json();
  }
} catch (error) {
  console.error('Failed to fetch competitions:', error);
  fetchError = true;
}

// Status badge config
const statusStyle: Record<string, { label: string; badge: string }> = {
  Active:   { label: 'Active',    badge: 'bg-emerald-100 text-emerald-700 border border-emerald-200' },
  Upcoming: { label: 'Upcoming',  badge: 'bg-orange-100 text-orange-700 border border-orange-200' },
  Ended:    { label: 'Ended',     badge: 'bg-zinc-100 text-zinc-500 border border-zinc-200' },
};

function getStatus(raw: string) {
  const key = raw?.trim() ?? '';
  return statusStyle[key] ?? { label: key || 'TBD', badge: 'bg-zinc-100 text-zinc-500 border border-zinc-200' };
}

function formatDate(raw: string | undefined): string {
  if (!raw) return '';
  const d = new Date(raw);
  if (isNaN(d.getTime())) return String(raw);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'Asia/Tokyo' });
}
---

<Layout
  title="Competitions | aira"
  description="Compete in official aira races. Test your algorithm, climb the leaderboard, and win prizes."
  canonicalUrl={landing.site.url + '/competitions'}
  ogImage={landing.site.ogImage}
  siteName={landing.site.name}
  lang={landing.site.lang}
>
  <Header />
  <main class="bg-arena-bg min-h-screen">

    <!-- Page hero -->
    <div class="relative pt-24 pb-16 px-4 sm:px-6 border-b border-arena-border overflow-hidden">
      <div
        class="absolute inset-0 pointer-events-none"
        style="background-image: linear-gradient(to right, #e4e4e7 1px, transparent 1px), linear-gradient(to bottom, #e4e4e7 1px, transparent 1px); background-size: 48px 48px; opacity: 0.4;"
        aria-hidden="true"
      ></div>
      <div class="relative max-w-3xl mx-auto text-center">
        <span class="inline-block text-xs font-semibold tracking-widest text-orange-500 uppercase mb-4">Compete</span>
        <h1 class="text-4xl sm:text-5xl font-light tracking-tight text-arena-ink">
          Competitions
        </h1>
        <p class="mt-6 text-lg text-arena-muted max-w-xl mx-auto">
          Official aira races. Submit your algorithm, beat the leaderboard, and earn prize money.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="/getting-started"
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-sky-500 rounded-full hover:bg-sky-600 transition-colors"
          >
            New? Start the Tutorial →
          </a>
          <a
            href="/#ranking"
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-arena-ink border border-arena-border rounded-full hover:border-zinc-400 transition-colors"
          >
            View Ranking
          </a>
        </div>
      </div>
    </div>

    <!-- Competitions list -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">

      {fetchError ? (
        <!-- Error state -->
        <div class="max-w-xl mx-auto text-center bg-red-50 border border-red-200 rounded-2xl px-8 py-10">
          <p class="text-red-600 font-semibold text-lg">Could not load competitions</p>
          <p class="mt-2 text-sm text-red-500">The server returned an error. Please try refreshing the page.</p>
        </div>
      ) : competitions.length === 0 ? (
        <!-- Empty state -->
        <div class="max-w-xl mx-auto text-center bg-arena-surface border border-arena-border rounded-2xl px-8 py-16">
          <div class="mx-auto mb-5 h-14 w-14 rounded-full bg-zinc-100 flex items-center justify-center">
            <svg class="h-7 w-7 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
            </svg>
          </div>
          <p class="text-lg font-light text-arena-ink">No competitions yet</p>
          <p class="mt-2 text-sm text-arena-muted">The first race is coming soon. Get your algorithm ready!</p>
          <a
            href="/getting-started"
            class="mt-6 inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-sky-500 rounded-full hover:bg-sky-600 transition-colors"
          >
            Start the Tutorial →
          </a>
        </div>
      ) : (
        <!-- Competition cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {competitions.map((comp) => {
            const st = getStatus(comp.Status);
            return (
              <div class="flex flex-col bg-white border border-arena-border rounded-2xl shadow-sm overflow-hidden hover:-translate-y-0.5 transition-transform duration-200">
                <!-- Card header -->
                <div class="px-6 pt-6 pb-4 border-b border-arena-border">
                  <div class="flex items-start justify-between gap-3">
                    <h2 class="text-base font-semibold text-arena-ink leading-snug">{comp.Title || 'Untitled Competition'}</h2>
                    <span class={`text-xs font-semibold px-2.5 py-1 rounded-full shrink-0 ${st.badge}`}>{st.label}</span>
                  </div>
                  {comp.Description && (
                    <p class="mt-2 text-sm text-arena-muted leading-relaxed">{comp.Description}</p>
                  )}
                </div>

                <!-- Card body -->
                <div class="px-6 py-4 space-y-2 grow">
                  {comp.StartDate && (
                    <div class="flex items-center gap-2 text-sm text-arena-muted">
                      <svg class="h-4 w-4 shrink-0 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5" />
                      </svg>
                      <span>
                        {formatDate(comp.StartDate)}
                        {comp.EndDate ? ` – ${formatDate(comp.EndDate)}` : ''}
                      </span>
                    </div>
                  )}
                  {comp.Prize && (
                    <div class="flex items-center gap-2 text-sm text-orange-600 font-medium">
                      <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0" />
                      </svg>
                      <span>Prize: {comp.Prize}</span>
                    </div>
                  )}
                </div>

                <!-- Card footer -->
                <div class="px-6 pb-6">
                  <a
                    href={`/competitions/${comp.ID}`}
                    class="w-full inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-white bg-orange-500 rounded-full hover:bg-orange-600 transition-colors"
                  >
                    View Details →
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- Bottom CTA -->
    <div class="border-t border-arena-border">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 text-center">
        <h2 class="text-2xl font-light tracking-tight text-arena-ink">New to aira?</h2>
        <p class="mt-3 text-arena-muted">Follow the step-by-step tutorial and have your robot running in under 2 minutes.</p>
        <a
          href="/getting-started"
          class="mt-6 inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-sky-500 rounded-full hover:bg-sky-600 transition-colors"
        >
          Start the Tutorial →
        </a>
      </div>
    </div>

  </main>
  <Footer {...landing.footer} />
</Layout>
